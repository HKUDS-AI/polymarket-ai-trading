# OpenAI key for AI market filtering (optional but recommended)
OPENAI_API_KEY=

# Enable real execution (default false keeps paper trading mode)
LIVE_TRADING=false

# Polygon wallet private key for live orders (optional)
# Primary key name:
POLYGON_PRIVATE_KEY=
# Backward-compatible alias:
POLYGON_WALLET_PRIVATE_KEY=

# Safety controls
KILL_SWITCH=false
MAX_DAILY_LOSS_USD=200
CLEAR_PAPER_DATA=false
